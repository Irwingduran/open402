{
  "name": "@open402/bot",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file .env src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup src/index.ts --format esm",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@open402/agents": "workspace:*",
    "@open402/db": "workspace:*",
    "grammy": "^1.22.0",
    "openai": "^6.42.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0"
  }
}
